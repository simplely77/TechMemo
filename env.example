# 复制为 .env 后由 docker compose 读取（.env 已在 .gitignore）
# 必需：大模型 API
APP_AI_CHAT_API_KEY=your-key-here

# 可选：覆盖 chat 供应商（默认与 config 默认值/compose 中一致时不必写）
# APP_AI_CHAT_PROVIDER=deepseek
# APP_AI_CHAT_MODEL=deepseek-chat
# APP_AI_CHAT_BASE_URL=https://api.deepseek.com

# 生产建议修改（docker-compose 未单独设置时可在此覆盖）
# APP_JWT_SECRET= change-me-in-production
# APP_DATABASE_PASSWORD=postgres
